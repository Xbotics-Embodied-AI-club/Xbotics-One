# 本地密钥与环境（只提交 .env.example / .envrc.example）
.env
.envrc

# uv 虚拟环境
.venv/
.venv_*/

# lerobot 上游源码（由 lerobot/fetch_lerobot.sh 拉取并打补丁，不入库）
lerobot/lerobot/

# 官方 RDK 工具（由 lerobot/rdk/fetch_rdk_tools.sh 拉取，不入库）
lerobot/rdk/rdk_LeRobot_tools/

# 运行结果 / 录制产物 / 缓存（已入库的 result/ 演示图保留）
.result/
recordings/
scratch/
__pycache__/
*.pyc
.ipynb_checkpoints/

# 训练输出
outputs/
wandb/
