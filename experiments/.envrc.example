# 复制为 .envrc 后 `direnv allow`（需安装 direnv）。把 .env 的值加载进来，
# 并由 DATASETS_ROOT 派生 HuggingFace / lerobot 缓存路径。

dotenv .env

# 由数据集根派生（代码与 lerobot 都按这些变量读写缓存）
export HF_HOME="${DATASETS_ROOT}/hfcache"   # HF 下载缓存，默认落在仓库本地
export HF_LEROBOT_HOME="${HF_HOME}/lerobot"

# uv 虚拟环境位置（默认 ./.venv，按需改到大盘）
# export UV_PROJECT_ENVIRONMENT="${PWD}/.venv"
