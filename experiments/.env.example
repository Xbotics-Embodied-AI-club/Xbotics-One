# 复制为 .env 并填入自己的值；.env 已被 .gitignore，不要提交真实 token。
# 代码直接读取这些环境变量，不设默认值，请确保已设置。

# —— 账号 token ——
HF_TOKEN=hf_your_token_here
HUGGING_FACE_HUB_TOKEN=hf_your_token_here
WANDB_API_KEY=your_wandb_key_here

# —— 大文件 / 数据集根（按自己机器的挂载点设置）——
# DATASETS_ROOT 是一切数据集 / 模型产物的根；HF_HOME、HF_LEROBOT_HOME 由它派生（见 .envrc.example）。
DATASETS_ROOT=/path/to/your/datasets

# —— lerobot 源拉取（fetch_lerobot.sh 用；不填用脚本默认）——
# LEROBOT_URL=https://github.com/huggingface/lerobot.git
# LEROBOT_REF=v0.5.1
